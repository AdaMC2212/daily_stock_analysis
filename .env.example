# US stock analyzer (Gemini + Telegram) minimal configuration

# Watchlist (US tickers and US indices)
STOCK_LIST=

# LLM (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACK=gemini-2.0-flash
LITELLM_MODEL=gemini/gemini-2.5-flash

# Optional news search providers
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=
BOCHA_API_KEYS=
NEWS_MAX_AGE_DAYS=30

# Runtime
MARKET_REVIEW_ENABLED=true
MARKET_REVIEW_REGION=us
TRADING_DAY_CHECK_ENABLED=true
SINGLE_STOCK_NOTIFY=false
MAX_WORKERS=3
LOG_LEVEL=INFO
HISTORICAL_LOOKBACK_DAYS=252
POST_MARKET_DELAY=30

# Optional schedule
# Use local wall-clock time with TIMEZONE instead of doing UTC math by hand.
# 08:00 in Asia/Kuala_Lumpur aligns with the prior US session after the close.
SCHEDULE_ENABLED=true
TIMEZONE=Asia/Kuala_Lumpur
SCHEDULE_TIME=08:00
SCHEDULE_RUN_IMMEDIATELY=true

# ── Telegram 通知 ──────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# ── Google Sheets 持仓读取（只读）─────────────
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SHEET_TAB=Portfolio

# ── 股票分层配置 ───────────────────────────────
TIER1_STOCKS=
TIER2_STOCKS=

# ── 每月定投日期 ───────────────────────────────
MONTHLY_DEPOSIT_DATE=1
MONTHLY_BUDGET=

# ── 新闻回溯天数（建议改为30天）────────────────
NEWS_MAX_AGE_DAYS=30

# Signal filtering
BUY_ALERT_MIN_SCORE=70
BUY_ALERT_ENABLED=true
DAILY_DIGEST_ENABLED=true

# Portfolio-aware market review
PORTFOLIO_IMPACT_ENABLED=true

# Telegram bot listener
BOT_LISTENER_ENABLED=true
BOT_LISTENER_POLL_INTERVAL=5
CONCENTRATION_WARN_THRESHOLD=60

# Earnings evaluator
EARNINGS_EVAL_ENABLED=true
FMP_API_KEY=your_key_here
EARNINGS_LOOKBACK_DAYS=7

